{
  "expo": {
    "name": "zeliaoms",
    "slug": "zeliaoms",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mipmap-xxxhdpi/ic_launcher_foreground.png",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/mipmap-xxxhdpi/ic_launcher_foreground.png",
        "backgroundColor": "#1565C0"
      },
      "package": "ke.co.mcdave.zeliaoms",
      "jsEngine": "hermes",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enablePngCrunchInReleaseBuilds": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0d6997ab-de31-4c8b-a898-4058881f6e6a"
      }
    }
  }
}
