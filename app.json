{
  "expo": {
    "name": "zeliaoms",
    "slug": "zeliaoms",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "light",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#2D8659"
      },
      "package": "ke.co.mcdave.zeliaoms",
      "jsEngine": "hermes",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enablePngCrunchInReleaseBuilds": true,
            "enableProguardInReleaseBuilds": true,
            "useLegacyPackaging": false,
            "abiFilters": ["arm64-v8a", "armeabi-v7a"]
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ZeliaOMS to access your camera for feedback photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow ZeliaOMS to access your location for visit tracking."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0d6997ab-de31-4c8b-a898-4058881f6e6a"
      }
    }
  }
}
